<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Airbender Platform API Docs</title>
    <style>
      :root {
        color-scheme: light dark;
        --bg: #f5f1e8;
        --panel: rgba(255, 255, 255, 0.86);
        --ink: #1c1a17;
        --muted: #61584d;
        --line: rgba(28, 26, 23, 0.12);
        --accent: #ab3f1f;
        --accent-ink: #7a2c14;
        --shadow: 0 24px 60px rgba(70, 45, 20, 0.12);
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #1e1b18;
          --panel: rgba(34, 29, 25, 0.92);
          --ink: #f5efe7;
          --muted: #d4c4b3;
          --line: rgba(245, 239, 231, 0.12);
          --accent: #ff8a5b;
          --accent-ink: #ffb191;
          --shadow: 0 24px 60px rgba(0, 0, 0, 0.28);
        }
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(circle at top left, rgba(171, 63, 31, 0.16), transparent 32%),
          radial-gradient(circle at top right, rgba(214, 151, 84, 0.2), transparent 28%),
          linear-gradient(180deg, rgba(255, 255, 255, 0.12), transparent 30%),
          var(--bg);
        color: var(--ink);
        font-family: "Iowan Old Style", "Palatino Linotype", "URW Palladio L", serif;
        line-height: 1.55;
      }

      main {
        width: min(960px, calc(100vw - 32px));
        margin: 40px auto;
        padding: 28px;
        border: 1px solid var(--line);
        border-radius: 28px;
        background: var(--panel);
        box-shadow: var(--shadow);
        backdrop-filter: blur(14px);
      }

      .eyebrow {
        margin: 0 0 10px;
        color: var(--accent);
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      h1 {
        margin: 0;
        font-size: clamp(2.2rem, 5vw, 4rem);
        line-height: 0.96;
        letter-spacing: -0.04em;
      }

      .lede {
        max-width: 42rem;
        margin: 18px 0 0;
        color: var(--muted);
        font-size: 1.05rem;
      }

      .crate-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 16px;
        list-style: none;
        padding: 0;
        margin: 32px 0 0;
      }

      .crate-card {
        padding: 18px 18px 16px;
        border: 1px solid var(--line);
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.48);
      }

      @media (prefers-color-scheme: dark) {
        .crate-card {
          background: rgba(255, 255, 255, 0.03);
        }
      }

      .crate-link {
        color: inherit;
        text-decoration: none;
      }

      .crate-link:hover .crate-name,
      .crate-link:focus-visible .crate-name {
        color: var(--accent);
      }

      .crate-name {
        margin: 0;
        font-size: 1.16rem;
        font-weight: 700;
        transition: color 140ms ease;
      }

      .crate-meta {
        margin: 10px 0 0;
        color: var(--muted);
        font-size: 0.95rem;
      }

      code {
        padding: 0.08rem 0.32rem;
        border-radius: 0.35rem;
        background: rgba(127, 107, 84, 0.12);
        font-family: "JetBrains Mono", "SFMono-Regular", ui-monospace, monospace;
        font-size: 0.92em;
      }
    </style>
  </head>
  <body>
    <main>
      <p class="eyebrow">Airbender Platform</p>
      <h1>Workspace API Docs</h1>
      <p class="lede">
        Rustdoc generates each workspace crate as its own entry point. This page
        keeps the published API docs navigable from a single stable URL.
      </p>
      <ul class="crate-grid">
        {{ crate_cards }}
      </ul>
    </main>
  </body>
</html>
